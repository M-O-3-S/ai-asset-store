{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Asset meta.json",
  "description": "AI Asset Store의 meta.json 파일 스키마. 에디터 자동완성 및 인라인 유효성 검사를 제공합니다.",
  "type": "object",
  "required": ["id", "type", "title", "description", "tags", "tools", "author", "version", "updated", "file", "preview"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema 참조 경로 (new-asset.js가 자동 삽입)"
    },
    "id": {
      "type": "string",
      "description": "레포 전체에서 유일한 asset 식별자. 소문자·숫자·하이픈만 사용.",
      "pattern": "^[a-z0-9-]+$",
      "examples": ["react-code-review", "python-type-checker", "embedded-c-refactor"]
    },
    "type": {
      "type": "string",
      "description": "asset 카테고리. SPEC.md S3 타입 레지스트리 참조.",
      "enum": ["skill", "rules", "persona", "prompt", "workflow"]
    },
    "title": {
      "type": "string",
      "description": "UI에 표시되는 asset 제목.",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "description": "asset을 2문장 이내로 설명하는 텍스트.",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "description": "검색 및 필터링에 사용되는 태그 목록.",
      "items": { "type": "string" },
      "minItems": 1,
      "examples": [["python", "review"], ["typescript", "lint"]]
    },
    "tools": {
      "type": "array",
      "description": "이 asset을 지원하는 AI 도구 목록.",
      "items": {
        "type": "string",
        "enum": ["cline", "cursor"]
      },
      "minItems": 1
    },
    "author": {
      "type": "string",
      "description": "작성자 이메일 또는 팀명.",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "description": "Semantic Versioning 형식 버전.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "examples": ["1.0.0", "1.2.3"]
    },
    "updated": {
      "type": "string",
      "description": "마지막 수정일 (YYYY-MM-DD 형식).",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "examples": ["2025-03-26"]
    },
    "file": {
      "type": "string",
      "description": "asset 본문 파일명. type별 규칙: skill→SKILL.md, rules→.clinerules, persona→persona.md, prompt→prompt.md, workflow→workflow.md",
      "enum": ["SKILL.md", ".clinerules", "persona.md", "prompt.md", "workflow.md"]
    },
    "preview": {
      "type": "string",
      "description": "검색 결과 카드에 노출되는 미리보기 텍스트. 200자 이하.",
      "minLength": 1,
      "maxLength": 200
    }
  }
}
